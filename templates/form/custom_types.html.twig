{% use 'form_div_layout.html.twig' %}

{% block form_errors %}
    <ul class="form_validation_errors">
        {% for error in errors %}
            <li class="form_validation_error">
                <i class="fa-solid fa-triangle-exclamation"></i>
                {{ error.getMessage() }}
            </li>
        {% endfor %}
    </ul>
{% endblock %}

{% block recaptcha_row %}
    <div class="pt-3">
        <div id="{{ name }}" data-control="{{ id }}" class="g-recaptcha" data-toggle="recaptcha" data-sitekey="{{ gg_recaptcha_site_key }}"></div>
    </div>
    {{ block('form_row') }}
{% endblock %}
